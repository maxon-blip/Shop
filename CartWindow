<Window x:Class="ShoesShop.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource Windows}"
        WindowStartupLocation="CenterScreen"
        Title="Корзина" Height="600" Width="900">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="16" Padding="20" Margin="0 0 0 16">
            <TextBlock Text="Корзина покупателя" FontSize="30" FontWeight="Bold"/>
        </Border>

        <DataGrid Grid.Row="1"
                  x:Name="CartGrid"
                  ItemsSource="{Binding CartItems}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  Margin="0 0 0 16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=N2}" IsReadOnly="True" Width="110"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice, StringFormat=N2}" IsReadOnly="True" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="18">
            <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 0 10">
                <TextBlock Text="Итого: " FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="{Binding TotalAmount, StringFormat=N2}" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text=" руб." FontSize="24" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Удалить выбранное" Click="RemoveButton_Click" Margin="5" Padding="10 5"/>
                <Button Content="Очистить" Click="ClearButton_Click" Margin="5" Padding="10 5"/>
                <Button Content="Оформить заказ" Click="OrderButton_Click" Margin="5" Padding="10 5"/>
                <Button Content="Назад к каталогу" Click="BackButton_Click" Margin="5" Padding="10 5"/>
            </StackPanel>
        </StackPanel>
        </Border>
    </Grid>
</Window>
