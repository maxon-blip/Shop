<Window x:Class="ShoesShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesShop"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        WindowStartupLocation="CenterScreen"
        Title="Авторизация" Height="540" Width="900" ResizeMode="NoResize">
    <Grid Margin="28">
        <Border Background="White" CornerRadius="24" BorderBrush="{StaticResource Line}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="24 0 0 24" Padding="42">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SHOE MARKET" Foreground="#93C5FD" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Foreground="White" FontSize="40" FontWeight="Bold" TextWrapping="Wrap" Margin="0 18 0 14"><Run Text="М"/><Run Language="ru-ru" Text="агазин обуви"/><LineBreak/><Run Language="ru-ru"/></TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="0 24 24 0" Padding="46 38">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Вход" FontSize="34" FontWeight="Bold" LineHeight="42" Margin="0 0 0 4"/>
                        <TextBlock Text="Введите данные пользователя" FontSize="16" Foreground="{StaticResource MutedText}" Margin="0 0 0 30"/>

                        <TextBlock Text="Логин" Foreground="{StaticResource MutedText}" Margin="0 0 0 8"/>
                        <TextBox x:Name="LoginEnter" Height="42" Margin="0 0 0 18"/>

                        <TextBlock Text="Пароль" Foreground="{StaticResource MutedText}" Margin="0 0 0 8"/>
                        <PasswordBox x:Name="PasswordEnter" Height="42" Margin="0 0 0 28"/>

                        <Button x:Name="LoginButton" Content="Войти в систему" Click="LoginButton_Click" Height="48"/>
                        <TextBlock Text="Войти как гость" HorizontalAlignment="Center" Foreground="{StaticResource Accent}" FontSize="15" FontWeight="SemiBold" Cursor="Hand" Margin="0 20 0 0" MouseDown="TextBlock_MouseDown"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
