<Window x:Class="ShoesShop.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesShop"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        WindowStartupLocation="CenterScreen"
        Title="Shoe Market — каталог" Height="820" Width="1240">
    <Grid Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="24" Padding="24" Margin="0 0 20 0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="SHOE MARKET" Foreground="#93C5FD" FontSize="15" FontWeight="Bold"/>
                    <TextBlock Text="Каталог" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0 14 0 8"/>
                    <TextBlock Text="{Binding UserInfo}" Foreground="#CBD5E1" TextWrapping="Wrap" LineHeight="21"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Button x:Name="AddProductButton" Content="+ Добавить товар" Click="AddProductButton_Click" Margin="0 0 0 10" IsEnabled="{Binding CanUseCart}"/>
                    <Button x:Name="CartButton" Content="Корзина (0)" Click="CartButton_Click" Margin="0 0 0 10"/>
                    <Button x:Name="LogOutButton" Content="Выйти" Click="LogOutButton_Click" Background="#334155" BorderBrush="#334155"/>
                </StackPanel>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Поиск" Foreground="#CBD5E1" Margin="0 0 0 6"/>
                    <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" Margin="0 0 0 16"/>

                    <TextBlock Text="Категория" Foreground="#CBD5E1" Margin="0 0 0 6"/>
                    <ComboBox x:Name="CategoryBox" SelectionChanged="CategoryBox_SelectionChanged" Margin="0 0 0 16"/>

                    <TextBlock Text="Бренд" Foreground="#CBD5E1" Margin="0 0 0 6"/>
                    <ComboBox x:Name="BrandBox" SelectionChanged="BrandBox_SelectionChanged" Margin="0 0 0 16"/>

                    <TextBlock Text="Сортировка" Foreground="#CBD5E1" Margin="0 0 0 6"/>
                    <ComboBox x:Name="SortBox" SelectionChanged="SortBox_SelectionChanged"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="22" Padding="24" Margin="0 0 0 16" BorderBrush="{StaticResource Line}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Выберите подходящую пару" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ProductList" ItemsSource="{Binding FilteredProducts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="278" MinHeight="430" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="20" Padding="16" Margin="0 0 18 18">
                                <StackPanel>
                                    <Border Background="{StaticResource SoftBg}" CornerRadius="18" Height="176" Padding="10" Margin="0 0 0 14">
                                        <Image Source="{Binding NewPhoto}" Stretch="Uniform"/>
                                    </Border>

                                    <TextBlock FontWeight="Bold" FontSize="18" TextWrapping="Wrap" LineHeight="23">
                                        <Run Text="{Binding Categories.Category}"/>
                                        <Run Text="  /  "/>
                                        <Run Text="{Binding ProductType.ProductType1}"/>
                                    </TextBlock>

                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Height="48" Margin="0 8 0 10"/>

                                    <TextBlock Margin="0 0 0 3"><Run Text="Бренд: " Foreground="{StaticResource MutedText}"/><Run Text="{Binding Producers.Producer}"/></TextBlock>
                                    <TextBlock Margin="0 0 0 3"><Run Text="Поставщик: " Foreground="{StaticResource MutedText}"/><Run Text="{Binding Suppliers.Supplier}"/></TextBlock>
                                    <TextBlock Margin="0 0 0 12"><Run Text="На складе: " Foreground="{StaticResource MutedText}"/><Run Text="{Binding QuantityInStock}"/></TextBlock>

                                    <TextBlock FontSize="22" FontWeight="Bold" Margin="0 0 0 14">
                                        <Run Text="{Binding Price}" Foreground="{Binding DiscountPriceStyler[0]}" TextDecorations="{Binding DiscountPriceStyler[1]}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding DiscountPriceStyler[2]}"/>
                                    </TextBlock>

                                    <Button Content="Добавить в корзину" Tag="{Binding}" Click="AddToCartButton_Click" IsEnabled="{Binding DataContext.CanUseCart, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0 0 0 8"/>
                                    <Button Content="Удалить" Tag="{Binding}" Click="DeleteProductButton_Click" IsEnabled="{Binding DataContext.CanUseCart, RelativeSource={RelativeSource AncestorType=Window}}" Background="{StaticResource Danger}" BorderBrush="{StaticResource Danger}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="2" Text="{Binding ProductsCounter}" HorizontalAlignment="Right" Foreground="{StaticResource MutedText}" Margin="0 12 10 0"/>
        </Grid>
    </Grid>
</Window>
